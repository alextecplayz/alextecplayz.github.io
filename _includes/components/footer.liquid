<!-- Overlay effects -->
<div id="effect-overlay" class="effect-overlay">
	<div class="vignette"></div>
	<div class="lightrope-background">
		<ul class="lightrope">
			{% for i in (1..42) %}
				<li></li>
			{% endfor %}
		</ul>
	</div>
</div>

<!-- Pop-up windows -->
<div class="pop-up settings-pop-up z-index100" id="settings-window">
	<div class="pop-up-content">
		<div class="pop-up-content-titlebar">
			<p class="flex centered grotesk semibold rem2 white pop-up-title">Settings</p>
			<a class="article-button-dark button-modal grotesk medium" href="#">Close</a>
		</div>
		<div class="pop-up-content-twopanes flexrow-to-col justify-center pop-up-content-scrollbox">
			<div class="flex column">
				<p class="monospace white bold rem1-25 pop-up-title">Theme to use:</p>
				<ul class="monospace white medium rem1">
					<li><p class="lightgray">Light Themes</p></li>
					<hr>
					<li><input type="radio" id="theme_calcitewhite" name="theme"><label for="theme_calcitewhite">Calcite White</label></li>
					<li><input type="radio" id="theme_slate" name="theme"><label for="theme_slate">Slate Gray</label></li>
					<li><input type="radio" id="theme_cream" name="theme"><label for="theme_cream">Orange Cream</label></li>
					<li><input type="radio" id="theme_sunnyforest" name="theme"><label for="theme_sunnyforest">Sunny Forest</label></li>
					<li><input type="radio" id="theme_sunnyocean" name="theme"><label for="theme_sunnyocean">Sunny Ocean</label></li>
					<li><input type="radio" id="theme_brightbook" name="theme"><label for="theme_brightbook">Bright Book</label></li>
					<li><input type="radio" id="theme_deeppastelpink" name="theme"><label for="theme_deeppastelpink">Deep Pastel Pink</label></li>
					<li><input type="radio" id="theme_halloweenlight" name="theme"><label for="theme_halloweenlight">Halloween Light (Autumn)</label></li>
					<li><input type="radio" id="theme_catlatte" name="theme"><label for="theme_catlatte">Catppuccin Latte</label></li>
					<li><p class="lightgray">Dark Themes</p></li>
					<hr>
					<li><input type="radio" id="theme_obsidiangray" name="theme" checked><label for="theme_obsidiangray">Obsidian Gray</label></li>
					<li><input type="radio" id="theme_transdark" name="theme"><label for="theme_transdark">Trans-Dark</label></li>
					<li><input type="radio" id="theme_darkforest" name="theme"><label for="theme_darkforest">Dark Forest</label></li>
					<li><input type="radio" id="theme_m3darkpink" name="theme"><label for="theme_m3darkpink">Material You Dark Colorful Pink</label></li>
					<li><input type="radio" id="theme_carmineaqua" name="theme"><label for="theme_carmineaqua">Carmine Aqua</label></li>
					<li><input type="radio" id="theme_orangeterm" name="theme"><label for="theme_orangeterm">Orange Terminal</label></li>
					<li><input type="radio" id="theme_halloweendark" name="theme"><label for="theme_halloweendark">Halloween Dark (Witching Hour)</label></li>
					<li><input type="radio" id="theme_catfrappe" name="theme"><label for="theme_catfrappe">Catppuccin Frappe</label></li>
					<li><input type="radio" id="theme_catmacchi" name="theme"><label for="theme_catmacchi">Catppuccin Macchiato</label></li>
					<li><input type="radio" id="theme_catmocha" name="theme"><label for="theme_catmocha">Catppuccin Mocha</label></li>
					<li><p class="lightgray">Dimmer Themes</p></li>
					<hr>
					<li><input type="radio" id="theme_deepspace" name="theme"><label for="theme_deepspace">Deep Space</label></li>
					<li><input type="radio" id="theme_matrixterm" name="theme"><label for="theme_matrixterm">Matrix Terminal</label></li>
					<li><p class="lightgray">AMOLED Themes</p></li>
					<hr>
					<li><input type="radio" id="theme_amoledblack" name="theme"><label for="theme_amoledblack">AMOLED Black</label></li>
					<li><p class="lightgray">Custom Themes</p></li>
					<hr>
					<li><input type="radio" id="theme_prisoniadark" name="theme"><label for="theme_prisoniadark">PRISONIA Dark</label></li>
					<li><input type="radio" id="theme_odysseylight" name="theme"><label for="theme_odysseylight">Odyssey Light</label></li>
					<li><input type="radio" id="theme_odysseydark" name="theme"><label for="theme_odysseydark">Odyssey Dark</label></li>
				</ul>
			</div>
			<div class="flex column">
				<p class="monospace white bold rem1-25 pop-up-title">Effects to apply:</p>
				<ul class="monospace white medium rem1">
					<li><p class="lightgray">Effects disabled (performance mode)</p></li>
					<hr>
					<li><input type="radio" id="effect_none" name="effects" checked><label for="effect_none">No effects</label></li>
					<li><p class="lightgray">Effects enabled (may be slower)</p></li>
					<hr>
					<li><input type="radio" id="effect_vignette" name="effects"><label for="effect_vignette">Vignette</label></li>
					<!-- Both rain and snow effects are broken :( <li><input type="radio" id="effect_rain" name="effects"><label for="effect_rain">Rain</label></li>
					<li><input type="radio" id="effect_snow" name="effects"><label for="effect_snow">Snow</label></li>-->
					<li><input type="radio" id="effect_lightrope" name="effects"><label for="effect_lightrope">Christmas Lights</label></li>
				</ul>
				<hr>
				<div class="flex column">
					<p class="monospace white bold rem1-25 pop-up-title">About website:</p>
					<a class="grotesk medium rem1-25 accent-color link" href="https://github.com/alextecplayz/alextecplayz.github.io/">Website v{{ site.ver_site }}</a>
					<p class="grotesk medium rem1-25 accent-color">Obsidian v{{ site.ver_obsidian }}</p>
					<p class="monospace lightgray medium rem1-25">&emsp;</p>
					<p class="monospace lightgray medium rem1-25">&emsp;</p>
					<a class="grotesk medium rem1-25 white link" href="{{ site.baseurl }}/terms">/terms</a>
					<a class="grotesk medium rem1-25 white link" href="{{ site.baseurl }}/privacy">/privacy</a>
					<a class="grotesk medium rem1-25 white link" href="{{ site.baseurl }}/about">/about</a>
					<a class="grotesk medium rem1-25 white link flex row" href="https://stats.alextecplayz.com">stats&nbsp;<p class="lightgray italic">Powered by Goatcounter</p></a>
					<p class="monospace lightgray medium rem1-25">&emsp;</p>
					<p class="monospace lightgray medium rem1-25">&emsp;</p>
					<p class="monospace white bold rem1-25">Note that without JavaScript, themes and effects will be applied only for the current page. Any navigation to other pages will reset them to default.</p>
				</div>
			</div>
		</div>
	</div>
</div>
<div id="share-section"></div>
<!-- Pop-up windows end -->

